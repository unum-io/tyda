------ Test: collect subquery
SELECT table1.value AS value FROM table1 WHERE aggregate(transform(coalesce((SELECT CASE WHEN (count(1) <> 0) THEN collect_list(table2.value) END AS value FROM table2), CAST(array() AS ARRAY<TINYINT>)), c0 -> (c0 = table1.value)), FALSE, (c1, c2) -> (c1 OR c2), c3 -> c3)
------ end

------ Test: count subquery
SELECT table1.value AS value FROM table1 WHERE (NOT (table1.value <= coalesce((SELECT CASE WHEN (count(1) <> 0) THEN count(CAST(1 AS INT)) END AS value FROM table2), CAST(0 AS BIGINT))))
------ end

------ Test: exists subquery
SELECT EXISTS (SELECT CAST(1 AS INT) AS value FROM table1 WHERE (NOT (table1.value <= CAST(0 AS BIGINT)))) AS value FROM table1
------ end

------ Test: exists subquery in where
SELECT table1.value AS value FROM table1 WHERE EXISTS (SELECT CAST(1 AS INT) AS value FROM table1 WHERE (NOT (table1.value <= CAST(0 AS BIGINT))))
------ end

------ Test: explode subquery
SELECT t0._1 AS _1, coalesce((SELECT CASE WHEN (count(1) <> 0) THEN count(CAST(1 AS INT)) END AS value FROM (SELECT explode(table2.value) AS _1 FROM table2) AS t1), CAST(0 AS BIGINT)) AS _2 FROM (SELECT explode(table1.value) AS _1 FROM table1) AS t0
------ end

------ Test: scalar subquery
SELECT table1.value AS value FROM table1 WHERE ((SELECT CASE WHEN (count(1) <> 0) THEN max(table1.value) END AS value FROM table1) IS NOT DISTINCT FROM table1.value)
------ end
