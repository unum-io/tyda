------ Test: collect subquery
SELECT t1.value AS value FROM t1 WHERE array_contains(coalesce((SELECT CASE WHEN (count(1) <> 0) THEN collect_list(t2.value) END AS value FROM t2), CAST(array() AS ARRAY<TINYINT>)), t1.value)
------ end

------ Test: count subquery
SELECT t1.value AS value FROM t1 WHERE (NOT (t1.value <= coalesce((SELECT CASE WHEN (count(1) <> 0) THEN count(CAST(1 AS INT)) END AS value FROM t2), CAST(0 AS BIGINT))))
------ end

------ Test: exists subquery
SELECT EXISTS (SELECT CAST(1 AS INT) AS value FROM t1 WHERE (NOT (t1.value <= CAST(0 AS BIGINT)))) AS value FROM t1
------ end

------ Test: exists subquery in where
SELECT t1.value AS value FROM t1 WHERE EXISTS (SELECT CAST(1 AS INT) AS value FROM t1 WHERE (NOT (t1.value <= CAST(0 AS BIGINT))))
------ end

------ Test: scalar subquery
SELECT t1.value AS value FROM t1 WHERE ((SELECT CASE WHEN (count(1) <> 0) THEN max(t1.value) END AS value FROM t1) IS NOT DISTINCT FROM t1.value)
------ end
