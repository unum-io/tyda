------ Test: fullJoinFlat
SELECT CASE WHEN (CASE WHEN (t0.value IS NOT NULL) THEN struct(t0.value.key AS key, t0.value.b AS b) END IS NULL) THEN struct(CAST(NULL AS TINYINT) AS key, CAST(NULL AS INT) AS b) ELSE struct(CASE WHEN (t0.value IS NOT NULL) THEN struct(t0.value.key AS key, t0.value.b AS b) END.key AS key, CASE WHEN (t0.value IS NOT NULL) THEN struct(t0.value.key AS key, t0.value.b AS b) END.b AS b) END.key AS key, CASE WHEN (CASE WHEN (t0.value IS NOT NULL) THEN struct(t0.value.key AS key, t0.value.b AS b) END IS NULL) THEN struct(CAST(NULL AS TINYINT) AS key, CAST(NULL AS INT) AS b) ELSE struct(CASE WHEN (t0.value IS NOT NULL) THEN struct(t0.value.key AS key, t0.value.b AS b) END.key AS key, CASE WHEN (t0.value IS NOT NULL) THEN struct(t0.value.key AS key, t0.value.b AS b) END.b AS b) END.b AS b, CASE WHEN (CASE WHEN (t1.value IS NOT NULL) THEN struct(t1.value.m1Key AS m1Key, t1.value.c AS c) END IS NULL) THEN struct(CAST(NULL AS TINYINT) AS m1Key, CAST(NULL AS INT) AS c) ELSE struct(CASE WHEN (t1.value IS NOT NULL) THEN struct(t1.value.m1Key AS m1Key, t1.value.c AS c) END.m1Key AS m1Key, CASE WHEN (t1.value IS NOT NULL) THEN struct(t1.value.m1Key AS m1Key, t1.value.c AS c) END.c AS c) END.m1Key AS m1Key, CASE WHEN (CASE WHEN (t1.value IS NOT NULL) THEN struct(t1.value.m1Key AS m1Key, t1.value.c AS c) END IS NULL) THEN struct(CAST(NULL AS TINYINT) AS m1Key, CAST(NULL AS INT) AS c) ELSE struct(CASE WHEN (t1.value IS NOT NULL) THEN struct(t1.value.m1Key AS m1Key, t1.value.c AS c) END.m1Key AS m1Key, CASE WHEN (t1.value IS NOT NULL) THEN struct(t1.value.m1Key AS m1Key, t1.value.c AS c) END.c AS c) END.c AS c FROM (SELECT struct(t1.key AS key, t1.b AS b) AS value FROM t1) AS t0 FULL JOIN (SELECT struct(t2.m1Key AS m1Key, t2.c AS c) AS value FROM t2) AS t1 ON (t0.value.key = t1.value.m1Key)
------ end

------ Test: fullOuterJoin
SELECT t0.value AS _1, t1.value AS _2 FROM (SELECT t1.value AS value FROM t1) AS t0 FULL JOIN (SELECT t2.value AS value FROM t2) AS t1 ON (t0.value = t1.value)
------ end

------ Test: fullOuterJoin nested Option
SELECT t0.value AS _1, t1.value AS _2 FROM (SELECT struct(t1.value AS value) AS value FROM t1) AS t0 FULL JOIN (SELECT struct(t2.value AS value) AS value FROM t2) AS t1 ON ((coalesce(t0.value.value, CAST(0 AS TINYINT)) = coalesce(t1.value.value, CAST(0 AS TINYINT))) AND ((t0.value.value IS NULL) = (t1.value.value IS NULL)))
------ end

------ Test: fullOuterJoin nested Option one side
SELECT t0.value AS _1, t1.value AS _2 FROM (SELECT struct(t1.value AS value) AS value FROM t1) AS t0 FULL JOIN (SELECT t2.value AS value FROM t2) AS t1 ON ((t0.value.value IS NOT NULL) AND (t0.value.value = t1.value))
------ end

------ Test: fullOuterJoin product
SELECT t0.value AS _1, t1.value AS _2 FROM (SELECT struct(t1._1 AS _1, t1._2 AS _2) AS value FROM t1) AS t0 FULL JOIN (SELECT struct(t2._1 AS _1, t2._2 AS _2) AS value FROM t2) AS t1 ON (t0.value._1 = t1.value._1)
------ end

------ Test: grouped leftAntiJoin
SELECT t1.value AS value FROM t1 WHERE (NOT EXISTS (SELECT t2.value AS value FROM t2 WHERE (t1.value = t2.value)))
------ end

------ Test: join
SELECT t1.value AS _1, t2.value AS _2 FROM t1 JOIN t2 ON (t1.value = t2.value)
------ end

------ Test: join and then explode
SELECT t0 AS _1, t1 AS _2 FROM t1 JOIN t2 ON (t1.a = t2.a), unnest(t1.d) AS t0, unnest(t2.d) AS t1
------ end

------ Test: join complex condition
SELECT struct(t1._1 AS _1, t1._2 AS _2) AS _1, struct(t2._1 AS _1, t2._2 AS _2) AS _2 FROM t1 JOIN t2 ON ((t1._1 = t2._1) AND ((t2._2 = t1._2) OR (t1._2 = CAST(0 AS TINYINT))))
------ end

------ Test: join complex not equi condition
SELECT t1.value AS _1, t2.value AS _2 FROM t1 JOIN t2 ON ((t1.value = t2.value) OR (t1.value = CAST(0 AS TINYINT)))
------ end

------ Test: join condition reverse order of exprs
SELECT t1.value AS _1, t2.value AS _2 FROM t1 JOIN t2 ON (t2.value = t1.value)
------ end

------ Test: join filter on both sides
SELECT t1.value AS _1, t2.value AS _2 FROM t1 JOIN t2 ON (t1.value = t2.value) WHERE ((t1.value < CAST(0 AS TINYINT)) AND (t2.value < CAST(5 AS TINYINT)))
------ end

------ Test: join filter on lhs
SELECT t1.value AS _1, t2.value AS _2 FROM t1 JOIN t2 ON (t1.value = t2.value) WHERE (t1.value < CAST(0 AS TINYINT))
------ end

------ Test: join filter on rhs
SELECT t1.value AS _1, t2.value AS _2 FROM t1 JOIN t2 ON (t1.value = t2.value) WHERE (t2.value < CAST(0 AS TINYINT))
------ end

------ Test: join multiple keys
SELECT struct(t1._1 AS _1, t1._2 AS _2) AS _1, struct(t2._1 AS _1, t2._2 AS _2) AS _2 FROM t1 JOIN t2 ON ((t1._1 = t2._1) AND (t1._2 = t2._2))
------ end

