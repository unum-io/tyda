------ Test: self join
SELECT struct(t1._1 AS _1, t1._2 AS _2) AS _1, struct(t1._1 AS _1, t1._2 AS _2) AS _2 FROM t1 JOIN t1 ON (t1._1 = t1._2)
------ end

------ Test: self join indirect
SELECT struct(struct(t1._1 AS _1, t1._2 AS _2) AS _1, struct(t2._1 AS _1, t2._2 AS _2) AS _2) AS _1, struct(t0._1 AS _1, t0._2 AS _2) AS _2 FROM t1 JOIN t2 ON (t1._1 = t2._1) JOIN (SELECT struct(t1._1 AS _1, t1._2 AS _2) AS _1, struct(t3._1 AS _1, t3._2 AS _2) AS _2 FROM t1 JOIN t3 ON (t1._1 = t3._1)) AS t0 ON (t1._2 = t0._1._2)
