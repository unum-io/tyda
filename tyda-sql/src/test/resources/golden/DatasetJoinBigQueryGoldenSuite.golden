SELECT t1.value AS _1, t0.value AS _2 FROM t1 LEFT JOIN (SELECT struct(t2.value AS value) AS value FROM t2) AS t0 ON ((t0.value.value IS NOT NULL) AND (t0.value.value = t1.value))
