------ Test: self leftAntiJoin after overlapping join
SELECT struct(t1._1 AS _1, t1._2 AS _2) AS _1, struct(t2._1 AS _1, t2._2 AS _2) AS _2 FROM t1 JOIN t2 ON (t1._1 = t2._1) WHERE (NOT EXISTS (SELECT struct(t1._1 AS _1, t1._2 AS _2) AS _1, struct(t3._1 AS _1, t3._2 AS _2) AS _2 FROM t1 JOIN t3 ON (t1._1 = t3._1) WHERE (t1._1 = t1._1)))
