SELECT CASE WHEN (t0.value IS NOT NULL) THEN t0.value._2 END AS _1, CASE WHEN (t1.value IS NOT NULL) THEN t1.value._2 END AS _2 FROM (SELECT struct(t1.value AS _1, t1.value AS _2) AS value FROM t1) AS t0 FULL JOIN (SELECT struct(t2.value AS _1, t2.value AS _2) AS value FROM t2) AS t1 ON (t0.value._1 = t1.value._1)
------ end

