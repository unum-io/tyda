------ end

------ Test: self join mutiple left
SELECT struct(struct(t1._1 AS _1, t1._2 AS _2) AS _1, struct(t2._1 AS _1, t2._2 AS _2) AS _2) AS _1, struct(t1._1 AS _1, t1._2 AS _2) AS _2 FROM t1 JOIN t2 ON (t1._1 = t2._1) JOIN t1 ON (t1._2 = t1._2)
