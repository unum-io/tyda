------ Test: minBy
SELECT t1._1 AS _1, min_by(struct(t1._1 AS _1, t1._2 AS _2)._1, struct(t1._1 AS _1, t1._2 AS _2)._2) AS _2 FROM t1 GROUP BY t1._1
------ end

------ Test: reduce group by nested option
SELECT count(CAST(1 AS INT)) AS value FROM (SELECT t1.value AS _1, struct(CASE WHEN CASE WHEN (t1.value IS NULL) THEN TRUE ELSE (NOT (t1.value <= CAST(0 AS INT))) END THEN struct(t1.value AS value) END AS key) AS _2 FROM t1) AS t0 GROUP BY t0._2
------ end

------ Test: reduce group by option.map with struct
SELECT count(CAST(1 AS INT)) AS value FROM (SELECT t1.value AS _1, struct(CASE WHEN (t1.value IS NOT NULL) THEN struct(t1.value._1 AS _1, CAST(1 AS INT) AS _2) END AS key) AS _2 FROM t1) AS t0 GROUP BY t0._2
------ end

------ Test: reduce group by option.orElse with struct
SELECT count(CAST(1 AS INT)) AS value FROM (SELECT t1.value AS _1, struct(coalesce(t1.value, struct(CAST(0 AS INT) AS _1, CAST(0 AS INT) AS _2)) AS key) AS _2 FROM t1) AS t0 GROUP BY t0._2
------ end

