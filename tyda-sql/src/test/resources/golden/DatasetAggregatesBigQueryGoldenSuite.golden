------ Test: aggregate 2 whole dataset
SELECT CASE WHEN (count(1) <> 0) THEN struct(count(CAST(1 AS INT)) AS _1, array_agg(t1.value) AS _2) END AS value FROM t1
------ end

------ Test: aggregate 3 whole dataset
SELECT CASE WHEN (count(1) <> 0) THEN struct(count(CAST(1 AS INT)) AS _1, array_agg(t1.value) AS _2, min(t1.value) AS _3) END AS value FROM t1
------ end

------ Test: aggregate 4 whole dataset
SELECT CASE WHEN (count(1) <> 0) THEN struct(count(CAST(1 AS INT)) AS _1, array_agg(t1.value) AS _2, min(t1.value) AS _3, max(t1.value) AS _4) END AS value FROM t1
------ end

------ Test: aggregate 5 whole dataset
SELECT CASE WHEN (count(1) <> 0) THEN struct(count(CAST(1 AS INT)) AS _1, array_agg(struct(t1._1 AS _1, t1._2 AS _2)) AS _2, min(t1._1) AS _3, max(t1._1) AS _4, min(t1._2) AS _5) END AS value FROM t1
------ end

------ Test: aggregate 6 whole dataset
SELECT CASE WHEN (count(1) <> 0) THEN struct(count(CAST(1 AS INT)) AS _1, array_agg(struct(t1._1 AS _1, t1._2 AS _2)) AS _2, min(t1._1) AS _3, max(t1._1) AS _4, min(t1._2) AS _5, max(t1._2) AS _6) END AS value FROM t1
------ end

------ Test: aggregate 7 whole dataset
SELECT CASE WHEN (count(1) <> 0) THEN struct(count(CAST(1 AS INT)) AS _1, array_agg(struct(t1._1 AS _1, t1._2 AS _2)) AS _2, min(t1._1) AS _3, max(t1._1) AS _4, min(t1._2) AS _5, max(t1._2) AS _6, array_agg(t1._2) AS _7) END AS value FROM t1
------ end

------ Test: aggregate 8 whole dataset
SELECT CASE WHEN (count(1) <> 0) THEN struct(count(CAST(1 AS INT)) AS _1, array_agg(struct(t1._1 AS _1, t1._2 AS _2)) AS _2, min(t1._1) AS _3, max(t1._1) AS _4, min(t1._2) AS _5, max(t1._2) AS _6, array_agg(t1._2) AS _7, sum(t1._1) AS _8) END AS value FROM t1
------ end

------ Test: aggregate collect whole dataset
SELECT CASE WHEN (count(1) <> 0) THEN array_agg(t1.value) END AS value FROM t1
------ end

------ Test: aggregate count whole dataset
SELECT CASE WHEN (count(1) <> 0) THEN count(CAST(1 AS INT)) END AS value FROM t1
------ end

------ Test: aggregate max whole dataset
SELECT CASE WHEN (count(1) <> 0) THEN max(t1.value) END AS value FROM t1
------ end

------ Test: aggregate minBy and maxBy
SELECT t1._1 AS key, min_by(struct(t1._1 AS _1, t1._2 AS _2)._1, struct(t1._1 AS _1, t1._2 AS _2)._2) AS min, max_by(struct(t1._1 AS _1, t1._2 AS _2)._1, struct(t1._1 AS _1, t1._2 AS _2)._2) AS max FROM t1 GROUP BY t1._1
------ end

------ Test: aggregate nested Option
SELECT CASE WHEN (count(1) <> 0) THEN struct(sum(t1.value) AS value) END AS value FROM t1
------ end

------ Test: boolAnd expr
SELECT logical_and((NOT (t1._2 <= CAST(0 AS INT)))) AS value FROM t1 GROUP BY t1._1
------ end

------ Test: boolAnd whole row
SELECT CASE WHEN (count(1) <> 0) THEN logical_and(t1.value) END AS value FROM t1
------ end

------ Test: boolOr expr
SELECT logical_or((NOT (t1._2 <= CAST(0 AS INT)))) AS value FROM t1 GROUP BY t1._1
------ end

------ Test: boolOr whole row
SELECT CASE WHEN (count(1) <> 0) THEN logical_or(t1.value) END AS value FROM t1
------ end

------ Test: collect Option
SELECT array_agg(t1.value) AS value FROM t1 GROUP BY CAST(NULL AS INT)
------ end

------ Test: collect Option Seq
SELECT array_agg(struct(t1.value AS value)) AS value FROM t1 GROUP BY CAST(NULL AS INT)
------ end

------ Test: collect Seq
SELECT array_agg(struct(t1.value AS value)) AS value FROM t1 GROUP BY CAST(NULL AS INT)
------ end

------ Test: collect and map
SELECT array((SELECT (CAST(c0 AS INT) + CAST(1 AS INT)) FROM unnest(t0.value) AS c0)) AS value FROM (SELECT array_agg(t1._2) AS value FROM t1 GROUP BY t1._1) AS t0
------ end

------ Test: collect and map pairs
SELECT t0._1 AS _1, array((SELECT (CAST(c0 AS INT) + CAST(1 AS INT)) FROM unnest(t0._2) AS c0)) AS _2 FROM (SELECT t1._1 AS _1, array_agg(t1._2) AS _2 FROM t1 GROUP BY t1._1) AS t0
------ end

------ Test: collect column
SELECT array_agg(t1._2) AS value FROM t1 GROUP BY t1._1
------ end

------ Test: collect whole row
SELECT array_agg(t1.value) AS value FROM t1 GROUP BY CAST(NULL AS INT)
------ end

------ Test: count group by
SELECT t1._1 AS _1, count(CAST(1 AS INT)) AS _2 FROM t1 GROUP BY t1._1
------ end

------ Test: count whole row
SELECT count(CAST(1 AS INT)) AS value FROM t1 GROUP BY CAST(NULL AS INT)
------ end

------ Test: countIf expr
SELECT count(CASE WHEN (NOT (t1.value <= CAST(0 AS INT))) THEN CAST(1 AS INT) END) AS value FROM t1 GROUP BY CAST(NULL AS INT)
------ end

------ Test: countIf group by
SELECT t1._1 AS _1, count(CASE WHEN (NOT (t1._2 <= CAST(0 AS INT))) THEN CAST(1 AS INT) END) AS _2 FROM t1 GROUP BY t1._1
------ end

------ Test: countIf whole row
SELECT count(CASE WHEN t1.value THEN CAST(1 AS INT) END) AS value FROM t1 GROUP BY CAST(NULL AS INT)
------ end

------ Test: countSome expr
SELECT count(t1._2) AS value FROM t1 GROUP BY t1._1
------ end

------ Test: countSome whole row
SELECT count(t1.value) AS value FROM t1 GROUP BY CAST(NULL AS INT)
------ end

------ Test: group by whole enum row
SELECT t1.discriminant AS discriminant, t1.a AS a, t1.b AS b, t1.c AS c FROM t1 GROUP BY t1.discriminant, t1.a, t1.b, t1.c
------ end

------ Test: group by whole nested Option row
SELECT t1.value AS value FROM t1 GROUP BY t1.value
------ end

------ Test: group by whole struct row
SELECT struct(t1._1 AS _1, t1._2 AS _2) AS _1, min(t1._1) AS _2 FROM t1 GROUP BY t1._1, t1._2
------ end

------ Test: groupBy transform
SELECT (NOT (t1._1 <= CAST(2 AS INT))) AS _1, min(t1._2) AS _2 FROM t1 GROUP BY (NOT (t1._1 <= CAST(2 AS INT)))
------ end

