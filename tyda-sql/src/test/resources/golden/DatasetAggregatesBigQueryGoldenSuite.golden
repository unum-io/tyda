------ end

------ Test: support group with complex literals
SELECT struct(struct(t1.value AS i, CAST(NULL AS STRING) AS a) AS i, CAST(NULL AS STRUCT<i INT,a STRING>) AS a) AS _1, count(CAST(1 AS INT)) AS _2 FROM t1 GROUP BY t1.value
------ end
