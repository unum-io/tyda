SELECT t1.key AS key, t1.b AS b, CASE WHEN (CASE WHEN (t0.value IS NOT NULL) THEN named_struct('m1Key', t0.value.m1Key, 'c', t0.value.c) END IS NULL) THEN named_struct('m1Key', CAST(NULL AS TINYINT), 'c', CAST(NULL AS INT)) ELSE named_struct('m1Key', CASE WHEN (t0.value IS NOT NULL) THEN named_struct('m1Key', t0.value.m1Key, 'c', t0.value.c) END.m1Key, 'c', CASE WHEN (t0.value IS NOT NULL) THEN named_struct('m1Key', t0.value.m1Key, 'c', t0.value.c) END.c) END.m1Key AS m1Key, CASE WHEN (CASE WHEN (t0.value IS NOT NULL) THEN named_struct('m1Key', t0.value.m1Key, 'c', t0.value.c) END IS NULL) THEN named_struct('m1Key', CAST(NULL AS TINYINT), 'c', CAST(NULL AS INT)) ELSE named_struct('m1Key', CASE WHEN (t0.value IS NOT NULL) THEN named_struct('m1Key', t0.value.m1Key, 'c', t0.value.c) END.m1Key, 'c', CASE WHEN (t0.value IS NOT NULL) THEN named_struct('m1Key', t0.value.m1Key, 'c', t0.value.c) END.c) END.c AS c FROM t1 LEFT JOIN (SELECT named_struct('m1Key', t2.m1Key, 'c', t2.c) AS value FROM t2) AS t0 ON (t1.key = t0.value.m1Key)
------ end

