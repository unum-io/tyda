SELECT named_struct('_1', named_struct('_1', t1._1, '_2', t1._2), '_2', named_struct('_1', t2._1, '_2', t2._2)) AS _1, named_struct('_1', t1._1, '_2', t1._2) AS _2 FROM t1 JOIN t2 ON (t1._1 = t2._1) JOIN t1 ON (t1._2 = t1._2)
