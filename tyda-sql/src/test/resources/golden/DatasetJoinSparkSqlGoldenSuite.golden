------ Test: self join mutiple left with aggregate
SELECT named_struct('_1', t0._1, '_2', t0._2) AS _1, named_struct('_1', t1._1, '_2', t1._2) AS _2 FROM (SELECT named_struct('_1', t1._1, '_2', t1._2) AS _1, named_struct('_1', t2._1, '_2', t2._2) AS _2 FROM t1 JOIN t2 ON (t1._1 = t2._1) GROUP BY t1._1, t1._2, t2._1, t2._2) AS t0 JOIN t1 ON (t0._1._2 = t1._2)
------ end

------ Test: self join mutiple left with distinct
