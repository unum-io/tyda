SELECT CASE WHEN (CASE WHEN (t0.value IS NOT NULL) THEN named_struct('key', t0.value.key, 'b', t0.value.b) END IS NULL) THEN named_struct('key', CAST(NULL AS TINYINT), 'b', CAST(NULL AS INT)) ELSE named_struct('key', CASE WHEN (t0.value IS NOT NULL) THEN named_struct('key', t0.value.key, 'b', t0.value.b) END.key, 'b', CASE WHEN (t0.value IS NOT NULL) THEN named_struct('key', t0.value.key, 'b', t0.value.b) END.b) END.key AS key, CASE WHEN (CASE WHEN (t0.value IS NOT NULL) THEN named_struct('key', t0.value.key, 'b', t0.value.b) END IS NULL) THEN named_struct('key', CAST(NULL AS TINYINT), 'b', CAST(NULL AS INT)) ELSE named_struct('key', CASE WHEN (t0.value IS NOT NULL) THEN named_struct('key', t0.value.key, 'b', t0.value.b) END.key, 'b', CASE WHEN (t0.value IS NOT NULL) THEN named_struct('key', t0.value.key, 'b', t0.value.b) END.b) END.b AS b, t2.m1Key AS m1Key, t2.c AS c FROM t2 LEFT JOIN (SELECT named_struct('key', t1.key, 'b', t1.b) AS value FROM t1) AS t0 ON (t0.value.key = t2.m1Key)
