------ Test: fullJoinFlat
SELECT CASE WHEN (CASE WHEN (t0.value IS NOT NULL) THEN named_struct('key', t0.value.key, 'b', t0.value.b) END IS NULL) THEN named_struct('key', CAST(NULL AS TINYINT), 'b', CAST(NULL AS INT)) ELSE named_struct('key', CASE WHEN (t0.value IS NOT NULL) THEN named_struct('key', t0.value.key, 'b', t0.value.b) END.key, 'b', CASE WHEN (t0.value IS NOT NULL) THEN named_struct('key', t0.value.key, 'b', t0.value.b) END.b) END.key AS key, CASE WHEN (CASE WHEN (t0.value IS NOT NULL) THEN named_struct('key', t0.value.key, 'b', t0.value.b) END IS NULL) THEN named_struct('key', CAST(NULL AS TINYINT), 'b', CAST(NULL AS INT)) ELSE named_struct('key', CASE WHEN (t0.value IS NOT NULL) THEN named_struct('key', t0.value.key, 'b', t0.value.b) END.key, 'b', CASE WHEN (t0.value IS NOT NULL) THEN named_struct('key', t0.value.key, 'b', t0.value.b) END.b) END.b AS b, CASE WHEN (CASE WHEN (t1.value IS NOT NULL) THEN named_struct('m1Key', t1.value.m1Key, 'c', t1.value.c) END IS NULL) THEN named_struct('m1Key', CAST(NULL AS TINYINT), 'c', CAST(NULL AS INT)) ELSE named_struct('m1Key', CASE WHEN (t1.value IS NOT NULL) THEN named_struct('m1Key', t1.value.m1Key, 'c', t1.value.c) END.m1Key, 'c', CASE WHEN (t1.value IS NOT NULL) THEN named_struct('m1Key', t1.value.m1Key, 'c', t1.value.c) END.c) END.m1Key AS m1Key, CASE WHEN (CASE WHEN (t1.value IS NOT NULL) THEN named_struct('m1Key', t1.value.m1Key, 'c', t1.value.c) END IS NULL) THEN named_struct('m1Key', CAST(NULL AS TINYINT), 'c', CAST(NULL AS INT)) ELSE named_struct('m1Key', CASE WHEN (t1.value IS NOT NULL) THEN named_struct('m1Key', t1.value.m1Key, 'c', t1.value.c) END.m1Key, 'c', CASE WHEN (t1.value IS NOT NULL) THEN named_struct('m1Key', t1.value.m1Key, 'c', t1.value.c) END.c) END.c AS c FROM (SELECT named_struct('key', t1.key, 'b', t1.b) AS value FROM t1) AS t0 FULL JOIN (SELECT named_struct('m1Key', t2.m1Key, 'c', t2.c) AS value FROM t2) AS t1 ON (t0.value.key = t1.value.m1Key)
------ end

------ Test: fullOuterJoin
SELECT t0.value AS _1, t1.value AS _2 FROM (SELECT t1.value AS value FROM t1) AS t0 FULL JOIN (SELECT t2.value AS value FROM t2) AS t1 ON (t0.value = t1.value)
------ end

------ Test: fullOuterJoin nested Option
SELECT t0.value AS _1, t1.value AS _2 FROM (SELECT named_struct('value', t1.value) AS value FROM t1) AS t0 FULL JOIN (SELECT named_struct('value', t2.value) AS value FROM t2) AS t1 ON (t0.value.value IS NOT DISTINCT FROM t1.value.value)
------ end

------ Test: fullOuterJoin nested Option one side
SELECT t0.value AS _1, t1.value AS _2 FROM (SELECT named_struct('value', t1.value) AS value FROM t1) AS t0 FULL JOIN (SELECT t2.value AS value FROM t2) AS t1 ON (t0.value.value IS NOT DISTINCT FROM t1.value)
------ end

------ Test: fullOuterJoin product
SELECT t0.value AS _1, t1.value AS _2 FROM (SELECT named_struct('_1', t1._1, '_2', t1._2) AS value FROM t1) AS t0 FULL JOIN (SELECT named_struct('_1', t2._1, '_2', t2._2) AS value FROM t2) AS t1 ON (t0.value._1 = t1.value._1)
------ end

