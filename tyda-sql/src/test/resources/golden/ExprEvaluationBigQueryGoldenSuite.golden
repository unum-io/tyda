------ Test: update adding new field
SELECT t1.a AS a, t1.b AS b, t1.c AS c, TRUE AS d FROM t1
------ end

------ Test: update replacing field and adding new field
SELECT t1.b AS b, t1.c AS c, t1.b AS a, t1.c AS d FROM t1
------ end

------ Test: update replacing field with different type
SELECT t1.b AS b, t1.c AS c, t1.b AS a FROM t1
------ end

------ Test: update replacing field with same type
SELECT t1._1.b AS b, t1._1.c AS c, t1._2.a AS a FROM t1
------ end

------ Test: when
SELECT CASE WHEN t1._1 THEN t1._2 END AS value FROM t1
------ end
