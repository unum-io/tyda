SELECT CAST((CAST(CAST((CAST(t1.value AS DECIMAL(38,6)) * CAST(1000000 AS INT)) AS BIGINT) AS DECIMAL(38,6)) / CAST(1000000 AS INT)) AS INTERVAL DAY TO SECOND) AS value FROM t1
------ end

