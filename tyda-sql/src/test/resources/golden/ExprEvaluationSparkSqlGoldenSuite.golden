------ Test: Date toDays
SELECT unix_date(t1.value) AS value FROM t1
------ end

------ Test: Date toDays toDate roundtrip
SELECT date_from_unix_date(unix_date(t1.value)) AS value FROM t1
------ end

------ Test: Duration toMicros
SELECT CAST((CAST(t1.value AS DECIMAL(38,6)) * CAST(1000000 AS INT)) AS BIGINT) AS value FROM t1
------ end

