------ Test: as
SELECT table1.a AS a, table1.b AS b FROM table1
------ end

------ Test: distinct List
SELECT DISTINCT table1.value AS value FROM table1
------ end

------ Test: distinct Option
SELECT DISTINCT table1.value AS value FROM table1
------ end

------ Test: distinct primitive
SELECT DISTINCT table1.value AS value FROM table1
------ end

------ Test: except
(SELECT table1.value AS value FROM table1) EXCEPT DISTINCT (SELECT table2.value AS value FROM table2)
------ end

------ Test: except on struct
(SELECT table1._1 AS _1, table1._2 AS _2 FROM table1) EXCEPT DISTINCT (SELECT table2._1 AS _1, table2._2 AS _2 FROM table2)
------ end

------ Test: except with self
(SELECT table1.value AS value FROM table1) EXCEPT DISTINCT (SELECT table1.value AS value FROM table1)
------ end

------ Test: explode Map
SELECT t0._1 AS _1, t0._2 AS _2 FROM table1, unnest(CAST(table1.value AS ARRAY<STRUCT<_1 INT,_2 INT>>)) AS t0
------ end

------ Test: explode Map and select Int
SELECT t0 AS _1, table1._2 AS _2 FROM table1, unnest(CAST(table1._1 AS ARRAY<STRUCT<_1 INT,_2 INT>>)) AS t0
------ end

------ Test: explode Option
SELECT table1.value AS value FROM table1 WHERE (table1.value IS NOT NULL)
------ end

------ Test: explode Seq
SELECT t0 AS value FROM table1, unnest(table1.value) AS t0
------ end

------ Test: explode Seq Option Seq
SELECT t1 AS value FROM table1, unnest(table1.value) AS t0, unnest(t0.value) AS t1 WHERE (t0.value IS NOT NULL)
------ end

------ Test: explode multiple nested Seq
SELECT t0.value AS _1, t1.value AS _2 FROM table1, unnest(table1._1) AS t0, unnest(table1._2) AS t1
------ end

------ Test: explode nested Seq
SELECT t1 AS value FROM table1, unnest(table1.value) AS t0, unnest(t0.value) AS t1
------ end

------ Test: limit after aggregate
SELECT table1._1 AS key, sum(table1._2) AS value FROM table1 GROUP BY table1._1 LIMIT 5
------ end

------ Test: limit after explode
SELECT t0 AS value FROM table1, unnest(table1._2) AS t0 LIMIT 5
------ end

------ Test: limit after filter
SELECT table1.value AS value FROM table1 WHERE (NOT (table1.value <= CAST(5 AS INT))) LIMIT 3
------ end

------ Test: limit after join
SELECT table1.value AS _1, table2.value AS _2 FROM table1 JOIN table2 ON (table1.value = table2.value) LIMIT 5
------ end

------ Test: limit after select
SELECT table1._1 AS _1, table1._2 AS _2 FROM table1 LIMIT 3
------ end

------ Test: limit basic
SELECT table1.value AS value FROM table1 LIMIT 5
------ end

------ Test: limit before aggregate
SELECT t0._1 AS key, sum(t0._2) AS value FROM (SELECT table1._1 AS _1, table1._2 AS _2 FROM table1 LIMIT 5) AS t0 GROUP BY t0._1
------ end

------ Test: limit before explode
SELECT t1 AS value FROM (SELECT table1._1 AS _1, table1._2 AS _2 FROM table1 LIMIT 5) AS t0, unnest(t0._2) AS t1
------ end

------ Test: limit before filter
SELECT t0.value AS value FROM (SELECT table1.value AS value FROM table1 LIMIT 5) AS t0 WHERE (NOT (t0.value <= CAST(2 AS INT)))
------ end

------ Test: limit before join
SELECT t0.value AS _1, table2.value AS _2 FROM (SELECT table1.value AS value FROM table1 LIMIT 5) AS t0 JOIN table2 ON (t0.value = table2.value)
------ end

------ Test: limit zero
SELECT table1.value AS value FROM table1 LIMIT 0
------ end

------ Test: nested option upcast
SELECT CASE WHEN (table1.value IS NOT NULL) THEN [table1.value.value] ELSE CAST([] AS ARRAY<INT>) END AS value FROM table1
------ end

------ Test: select 2
SELECT table1._1 AS _1, table1._2 AS _2 FROM table1
------ end

------ Test: select 3
SELECT table1._1 AS _1, table1._2 AS _2, table1._3 AS _3 FROM table1
------ end

------ Test: select 4
SELECT table1._1 AS _1, table1._2 AS _2, table1._3 AS _3, table1._4 AS _4 FROM table1
------ end

------ Test: select 5
SELECT table1._1 AS _1, table1._2 AS _2, table1._3 AS _3, table1._4 AS _4, table1._5 AS _5 FROM table1
------ end

------ Test: select 6
SELECT table1._1 AS _1, table1._2 AS _2, table1._3 AS _3, table1._4 AS _4, table1._5 AS _5, table1._6 AS _6 FROM table1
------ end

------ Test: select 7
SELECT table1._1 AS _1, table1._2 AS _2, table1._3 AS _3, table1._4 AS _4, table1._5 AS _5, table1._6 AS _6, table1._7 AS _7 FROM table1
------ end

------ Test: select 7 explode
SELECT t0 AS _1, t1 AS _2, t2 AS _3, t3 AS _4, t4 AS _5, t5 AS _6, t6 AS _7 FROM table1, unnest(table1._1) AS t0, unnest(table1._2) AS t1, unnest(table1._3) AS t2, unnest(table1._4) AS t3, unnest(table1._5) AS t4, unnest(table1._6) AS t5, unnest(table1._7) AS t6
------ end

------ Test: select Product
SELECT table1.value AS _1, CAST(1 AS INT) AS _2 FROM table1
------ end

------ Test: select complex
SELECT CAST(CAST([] AS ARRAY<STRUCT<_1 INT,_2 INT>>) AS ARRAY<STRUCT<key INT,value INT>>) AS value FROM table1
------ end

------ Test: select enum
SELECT table1.discriminant AS discriminant, table1.a AS a, table1.b AS b FROM table1
------ end

------ Test: select multiple explode options
SELECT table1._1 AS _1, table1._2 AS _2 FROM table1 WHERE ((table1._1 IS NOT NULL) AND (table1._2 IS NOT NULL))
------ end

------ Test: select multiple explode seq
SELECT t0 AS _1, t1 AS _2 FROM table1, unnest(table1._1) AS t0, unnest(table1._2) AS t1
------ end

------ Test: select nested access
SELECT table1._1._1 AS value FROM table1
------ end

------ Test: select primitive
SELECT CAST(1 AS INT) AS value FROM table1
------ end

------ Test: union
(SELECT table1.value AS value FROM table1) UNION ALL (SELECT table2.value AS value FROM table2)
------ end

------ Test: union on struct
(SELECT table1._1 AS _1, table1._2 AS _2 FROM table1) UNION ALL (SELECT table2._1 AS _1, table2._2 AS _2 FROM table2)
------ end

------ Test: union with self
(SELECT table1.value AS value FROM table1) UNION ALL (SELECT table1.value AS value FROM table1)
------ end

------ Test: where
SELECT table1.value AS value FROM table1 WHERE table1.value
------ end

------ Test: where literal
SELECT table1.value AS value FROM table1 WHERE TRUE
------ end

------ Test: where not
SELECT table1.value AS value FROM table1 WHERE (NOT table1.value)
------ end
