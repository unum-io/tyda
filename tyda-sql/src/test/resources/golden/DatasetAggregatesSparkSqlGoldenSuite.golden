------ Test: aggregate 2 whole dataset
SELECT CASE WHEN (count(1) <> 0) THEN named_struct('_1', count(CAST(1 AS INT)), '_2', collect_list(t1.value)) END AS value FROM t1
------ end

------ Test: aggregate 3 whole dataset
SELECT CASE WHEN (count(1) <> 0) THEN named_struct('_1', count(CAST(1 AS INT)), '_2', collect_list(t1.value), '_3', min(t1.value)) END AS value FROM t1
------ end

------ Test: aggregate 4 whole dataset
SELECT CASE WHEN (count(1) <> 0) THEN named_struct('_1', count(CAST(1 AS INT)), '_2', collect_list(t1.value), '_3', min(t1.value), '_4', max(t1.value)) END AS value FROM t1
------ end

------ Test: aggregate 5 whole dataset
SELECT CASE WHEN (count(1) <> 0) THEN named_struct('_1', count(CAST(1 AS INT)), '_2', collect_list(named_struct('_1', t1._1, '_2', t1._2)), '_3', min(t1._1), '_4', max(t1._1), '_5', min(t1._2)) END AS value FROM t1
------ end

------ Test: aggregate 6 whole dataset
SELECT CASE WHEN (count(1) <> 0) THEN named_struct('_1', count(CAST(1 AS INT)), '_2', collect_list(named_struct('_1', t1._1, '_2', t1._2)), '_3', min(t1._1), '_4', max(t1._1), '_5', min(t1._2), '_6', max(t1._2)) END AS value FROM t1
------ end

------ Test: aggregate 7 whole dataset
SELECT CASE WHEN (count(1) <> 0) THEN named_struct('_1', count(CAST(1 AS INT)), '_2', collect_list(named_struct('_1', t1._1, '_2', t1._2)), '_3', min(t1._1), '_4', max(t1._1), '_5', min(t1._2), '_6', max(t1._2), '_7', collect_list(t1._2)) END AS value FROM t1
------ end

------ Test: aggregate 8 whole dataset
SELECT CASE WHEN (count(1) <> 0) THEN named_struct('_1', count(CAST(1 AS INT)), '_2', collect_list(named_struct('_1', t1._1, '_2', t1._2)), '_3', min(t1._1), '_4', max(t1._1), '_5', min(t1._2), '_6', max(t1._2), '_7', collect_list(t1._2), '_8', sum(t1._1)) END AS value FROM t1
------ end

------ Test: aggregate collect whole dataset
SELECT CASE WHEN (count(1) <> 0) THEN collect_list(t1.value) END AS value FROM t1
------ end

------ Test: aggregate count whole dataset
SELECT CASE WHEN (count(1) <> 0) THEN count(CAST(1 AS INT)) END AS value FROM t1
------ end

------ Test: aggregate max whole dataset
SELECT CASE WHEN (count(1) <> 0) THEN max(t1.value) END AS value FROM t1
------ end

------ Test: aggregate minBy and maxBy
SELECT t1._1 AS key, min_by(named_struct('_1', t1._1, '_2', t1._2)._1, named_struct('_1', t1._1, '_2', t1._2)._2) AS min, max_by(named_struct('_1', t1._1, '_2', t1._2)._1, named_struct('_1', t1._1, '_2', t1._2)._2) AS max FROM t1 GROUP BY t1._1
------ end

------ Test: aggregate nested Option
SELECT CASE WHEN (count(1) <> 0) THEN named_struct('value', sum(t1.value)) END AS value FROM t1
------ end

------ Test: boolAnd expr
SELECT bool_and((NOT (t1._2 <= CAST(0 AS INT)))) AS value FROM t1 GROUP BY t1._1
------ end

------ Test: boolAnd whole row
SELECT CASE WHEN (count(1) <> 0) THEN bool_and(t1.value) END AS value FROM t1
------ end

------ Test: boolOr expr
SELECT bool_or((NOT (t1._2 <= CAST(0 AS INT)))) AS value FROM t1 GROUP BY t1._1
------ end

------ Test: boolOr whole row
SELECT CASE WHEN (count(1) <> 0) THEN bool_or(t1.value) END AS value FROM t1
------ end

------ Test: collect Option
SELECT transform(collect_list(named_struct('_1', t1.value)), c0 -> c0._1) AS value FROM t1 GROUP BY CAST(NULL AS INT)
------ end

------ Test: collect Option Seq
SELECT transform(collect_list(named_struct('_1', t1.value)), c0 -> c0._1) AS value FROM t1 GROUP BY CAST(NULL AS INT)
------ end

------ Test: collect Seq
SELECT collect_list(t1.value) AS value FROM t1 GROUP BY CAST(NULL AS INT)
------ end

------ Test: collect and map
SELECT transform(collect_list(t1._2), c0 -> (CAST(c0 AS INT) + CAST(1 AS INT))) AS value FROM t1 GROUP BY t1._1
------ end

------ Test: collect and map pairs
SELECT t1._1 AS _1, transform(collect_list(t1._2), c0 -> (CAST(c0 AS INT) + CAST(1 AS INT))) AS _2 FROM t1 GROUP BY t1._1
------ end

------ Test: collect column
SELECT collect_list(t1._2) AS value FROM t1 GROUP BY t1._1
------ end

------ Test: collect whole row
SELECT collect_list(t1.value) AS value FROM t1 GROUP BY CAST(NULL AS INT)
------ end

