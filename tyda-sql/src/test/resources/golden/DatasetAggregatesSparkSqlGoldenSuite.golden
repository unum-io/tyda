SELECT flatten(collect_list(table1._2)) AS value FROM table1 GROUP BY table1._1
------ end

------ Test: concat seq
SELECT flatten(collect_list(table1.value)) AS value FROM table1 GROUP BY CAST(NULL AS INT)
------ end

