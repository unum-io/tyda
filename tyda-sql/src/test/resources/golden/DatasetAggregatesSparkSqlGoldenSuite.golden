SELECT table1._1 AS _1, flatten(collect_list(table1._2)) AS _2 FROM table1 GROUP BY table1._1
------ end

------ Test: count group by
SELECT table1._1 AS _1, count(CAST(1 AS INT)) AS _2 FROM table1 GROUP BY table1._1
------ end

