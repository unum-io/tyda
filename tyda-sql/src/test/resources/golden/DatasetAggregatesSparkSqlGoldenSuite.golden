------ Test: aggregate 2 whole dataset
SELECT CASE WHEN (count(1) <> 0) THEN named_struct('_1', count(CAST(1 AS INT)), '_2', collect_list(table1.value)) END AS value FROM table1
------ end

------ Test: aggregate 3 whole dataset
SELECT CASE WHEN (count(1) <> 0) THEN named_struct('_1', count(CAST(1 AS INT)), '_2', collect_list(table1.value), '_3', min(table1.value)) END AS value FROM table1
------ end

------ Test: aggregate 4 whole dataset
SELECT CASE WHEN (count(1) <> 0) THEN named_struct('_1', count(CAST(1 AS INT)), '_2', collect_list(table1.value), '_3', min(table1.value), '_4', max(table1.value)) END AS value FROM table1
------ end

------ Test: aggregate 5 whole dataset
SELECT CASE WHEN (count(1) <> 0) THEN named_struct('_1', count(CAST(1 AS INT)), '_2', collect_list(named_struct('_1', table1._1, '_2', table1._2)), '_3', min(table1._1), '_4', max(table1._1), '_5', min(table1._2)) END AS value FROM table1
------ end

------ Test: aggregate 6 whole dataset
SELECT CASE WHEN (count(1) <> 0) THEN named_struct('_1', count(CAST(1 AS INT)), '_2', collect_list(named_struct('_1', table1._1, '_2', table1._2)), '_3', min(table1._1), '_4', max(table1._1), '_5', min(table1._2), '_6', max(table1._2)) END AS value FROM table1
------ end

------ Test: aggregate 7 whole dataset
SELECT CASE WHEN (count(1) <> 0) THEN named_struct('_1', count(CAST(1 AS INT)), '_2', collect_list(named_struct('_1', table1._1, '_2', table1._2)), '_3', min(table1._1), '_4', max(table1._1), '_5', min(table1._2), '_6', max(table1._2), '_7', collect_list(table1._2)) END AS value FROM table1
------ end

------ Test: aggregate 8 whole dataset
SELECT CASE WHEN (count(1) <> 0) THEN named_struct('_1', count(CAST(1 AS INT)), '_2', collect_list(named_struct('_1', table1._1, '_2', table1._2)), '_3', min(table1._1), '_4', max(table1._1), '_5', min(table1._2), '_6', max(table1._2), '_7', collect_list(table1._2), '_8', sum(table1._1)) END AS value FROM table1
------ end

------ Test: aggregate collect whole dataset
SELECT CASE WHEN (count(1) <> 0) THEN collect_list(table1.value) END AS value FROM table1
------ end

------ Test: aggregate count whole dataset
SELECT CASE WHEN (count(1) <> 0) THEN count(CAST(1 AS INT)) END AS value FROM table1
------ end

------ Test: aggregate max whole dataset
SELECT CASE WHEN (count(1) <> 0) THEN max(table1.value) END AS value FROM table1
------ end

------ Test: aggregate minBy and maxBy
SELECT table1._1 AS key, min_by(named_struct('_1', table1._1, '_2', table1._2)._1, named_struct('_1', table1._1, '_2', table1._2)._2) AS min, max_by(named_struct('_1', table1._1, '_2', table1._2)._1, named_struct('_1', table1._1, '_2', table1._2)._2) AS max FROM table1 GROUP BY table1._1
------ end

------ Test: aggregate nested Option
SELECT CASE WHEN (count(1) <> 0) THEN named_struct('value', sum(table1.value)) END AS value FROM table1
------ end

------ Test: boolAnd expr
SELECT bool_and((NOT (table1._2 <= CAST(0 AS INT)))) AS value FROM table1 GROUP BY table1._1
------ end

------ Test: boolAnd whole row
SELECT CASE WHEN (count(1) <> 0) THEN bool_and(table1.value) END AS value FROM table1
------ end

------ Test: boolOr expr
SELECT bool_or((NOT (table1._2 <= CAST(0 AS INT)))) AS value FROM table1 GROUP BY table1._1
------ end

------ Test: boolOr whole row
SELECT CASE WHEN (count(1) <> 0) THEN bool_or(table1.value) END AS value FROM table1
------ end

------ Test: collect Option
SELECT transform(collect_list(named_struct('_1', table1.value)), c0 -> c0._1) AS value FROM table1 GROUP BY CAST(NULL AS INT)
------ end

------ Test: collect Option Seq
SELECT transform(collect_list(named_struct('_1', table1.value)), c0 -> c0._1) AS value FROM table1 GROUP BY CAST(NULL AS INT)
------ end

